<div data-controller="homework">
  <div data-homework-target="storageWarning" class="storage-warning" hidden>
    Storage unavailable — your data won't be saved.
  </div>

  <div class="section-header">
    <h1 class="section-title">Homework</h1>
    <button class="btn btn--primary" data-action="homework#add">Add</button>
  </div>
  <div data-homework-target="form" hidden>
    <div class="inline-form">
      <div class="form-row">
        <div class="form-field">
          <label for="homework_title">Title</label>
          <input type="text" id="homework_title" data-homework-target="title" placeholder="Assignment title">
        </div>
        <div class="form-field">
          <label for="homework_subject">Subject</label>
          <select id="homework_subject" data-homework-target="subject">
            <option value="">— select a class —</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label for="homework_due_date">Due date</label>
          <input type="date" id="homework_due_date" data-homework-target="dueDate">
        </div>
        <div class="form-field">
          <label for="homework_estimate_minutes">Estimated minutes</label>
          <input type="number" id="homework_estimate_minutes" min="1" step="1" data-homework-target="estimateMinutes" placeholder="e.g. 45">
        </div>
      </div>
      <p class="error-msg" data-homework-target="error"></p>
      <div class="form-actions">
        <button class="btn btn--primary" data-action="homework#save">Save</button>
        <button class="btn btn--ghost" data-action="homework#cancel">Cancel</button>
      </div>
    </div>
  </div>

  <div data-homework-target="list"></div>
  <p class="edit-hint">click to edit</p>

  <div class="modal-backdrop" data-homework-target="modal" data-action="click->homework#closeEditorOnBackdrop" hidden>
    <div class="modal-card modal-card--with-close" role="dialog" aria-modal="true" aria-labelledby="homework_edit_heading">
      <button class="modal-close" aria-label="Close homework editor" data-action="homework#closeEditor">&times;</button>
      <h2 id="homework_edit_heading" class="modal-title">Edit homework</h2>
      <div class="form-row">
        <div class="form-field">
          <label for="homework_edit_title">Edit title</label>
          <input type="text" id="homework_edit_title" data-homework-target="modalTitle" placeholder="Assignment title">
        </div>
        <div class="form-field">
          <label for="homework_edit_subject">Edit subject</label>
          <select id="homework_edit_subject" data-homework-target="modalSubject">
            <option value="">— select a class —</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label for="homework_edit_due_date">Edit due date</label>
          <input type="date" id="homework_edit_due_date" data-homework-target="modalDueDate">
        </div>
        <div class="form-field">
          <label for="homework_edit_estimate_minutes">Edit estimated minutes</label>
          <input type="number" id="homework_edit_estimate_minutes" min="1" step="1" data-homework-target="modalEstimateMinutes" placeholder="e.g. 45">
        </div>
      </div>
      <p class="error-msg" data-homework-target="modalError"></p>
      <div class="form-actions">
        <button class="btn btn--primary" data-action="homework#saveEdit">Save changes</button>
        <button class="btn btn--danger" data-action="homework#requestDeleteConfirmation">Delete</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop modal-backdrop--confirm" data-homework-target="confirmModal" data-action="click->homework#closeDeleteConfirmOnBackdrop" hidden>
    <div class="modal-card modal-card--confirm" role="dialog" aria-modal="true" aria-labelledby="homework_delete_heading">
      <h2 id="homework_delete_heading" class="modal-title">Delete homework?</h2>
      <p class="modal-copy">This action can’t be undone.</p>
      <div class="form-actions">
        <button class="btn btn--danger" data-action="homework#deleteFromModal">Delete item</button>
        <button class="btn btn--ghost" data-action="homework#closeDeleteConfirm">Cancel</button>
      </div>
    </div>
  </div>
</div>
