<div data-controller="volunteer">
  <div data-volunteer-target="storageWarning" class="storage-warning" hidden>
    Storage unavailable — your data won't be saved.
  </div>

  <div class="section-header">
    <h1 class="section-title">Volunteer</h1>
    <div style="display:flex; align-items:center; gap:16px;">
      <span class="total-label">Total: <strong data-volunteer-target="totalHours">0</strong> hrs</span>
      <button class="btn btn--primary" data-action="volunteer#add">Add</button>
    </div>
  </div>

  <div data-volunteer-target="form" hidden>
    <div class="inline-form">
      <div class="form-row">
        <div class="form-field">
          <label for="volunteer_organization">Organization</label>
          <input type="text" id="volunteer_organization" data-volunteer-target="organization" placeholder="e.g. Local Food Bank">
        </div>
        <div class="form-field">
          <label for="volunteer_description">Description</label>
          <input type="text" id="volunteer_description" data-volunteer-target="description" placeholder="What did you do?">
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label for="volunteer_date">Date</label>
          <input type="text" id="volunteer_date" data-volunteer-target="date" placeholder="YYYY-MM-DD">
        </div>
        <div class="form-field">
          <label for="volunteer_hours">Hours</label>
          <input type="number" id="volunteer_hours" min="0.5" step="0.5" data-volunteer-target="hours" placeholder="e.g. 3">
        </div>
      </div>
      <p class="error-msg" data-volunteer-target="error"></p>
      <div class="form-actions">
        <button class="btn btn--primary" data-action="volunteer#save">Save</button>
        <button class="btn btn--ghost" data-action="volunteer#cancel">Cancel</button>
      </div>
    </div>
  </div>

  <div data-volunteer-target="list"></div>
</div>
