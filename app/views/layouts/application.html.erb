<!DOCTYPE html>
<html lang="en" data-storage-namespace="<%= review_mode? ? 'review' : '' %>" data-review-mode="<%= review_mode? %>">
  <head>
    <title>Student OS</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link
      rel="icon"
      type="image/svg+xml"
      data-theme-favicon="true"
      href="data:image/svg+xml,%3Csvg%20xmlns%3D%27http%3A//www.w3.org/2000/svg%27%20viewBox%3D%270%200%2032%2032%27%3E%3Crect%20width%3D%2732%27%20height%3D%2732%27%20rx%3D%276%27%20fill%3D%27%234f46e5%27/%3E%3C/svg%3E"
    >
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Lora:wght@400;500;600&family=Merriweather:wght@400;700&family=Press+Start+2P&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://w.soundcloud.com/player/api.js"></script>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <div class="app" data-controller="theme taskbar">
      <div class="sidebar-hover-zone" aria-hidden="true"></div>
      <aside class="sidebar">
        <div class="sidebar__title">Student OS</div>
        <%= link_to "Classes", app_path(:classes_path),
              class: "sidebar__link #{current_page?(app_path(:classes_path)) ? 'sidebar__link--active' : ''}" %>
        <%= link_to "Homework", app_path(:homework_path),
              class: "sidebar__link #{current_page?(app_path(:homework_path)) || current_page?(app_path(:root_path)) ? 'sidebar__link--active' : ''}" %>
        <%= link_to "Tests", app_path(:tests_path),
              class: "sidebar__link #{current_page?(app_path(:tests_path)) ? 'sidebar__link--active' : ''}" %>
        <%= link_to "Pomodoro", app_path(:pomodoro_path),
              class: "sidebar__link #{current_page?(app_path(:pomodoro_path)) ? 'sidebar__link--active' : ''}" %>
        <%= link_to "Volunteer", app_path(:volunteer_path),
              class: "sidebar__link #{current_page?(app_path(:volunteer_path)) ? 'sidebar__link--active' : ''}" %>
        <%= link_to "Extracurriculars", app_path(:extracurriculars_path),
              class: "sidebar__link #{current_page?(app_path(:extracurriculars_path)) ? 'sidebar__link--active' : ''}" %>
        <%= link_to "Music", app_path(:music_path),
              class: "sidebar__link #{current_page?(app_path(:music_path)) ? 'sidebar__link--active' : ''}" %>
      </aside>
      <main class="main">
        <%= yield %>
      </main>

      <footer class="taskbar">
        <div class="taskbar__left">
          <span class="taskbar__item" data-taskbar-target="pomodoro" hidden></span>
        </div>
        <div class="taskbar__right" data-taskbar-target="clock"></div>
      </footer>

      <div class="modal-backdrop modal-backdrop--confirm" data-taskbar-target="decisionModal" hidden>
        <div class="modal-card modal-card--confirm" role="dialog" aria-modal="true" aria-labelledby="pomodoro_end_heading">
          <h2 id="pomodoro_end_heading" class="modal-title">Work timer ended</h2>
          <p class="modal-copy">Start play time or stop the timer.</p>
          <div class="form-actions">
            <button class="btn btn--primary" data-action="taskbar#startPlayTime">Start play time</button>
            <button class="btn btn--ghost" data-action="taskbar#stopPomodoro">Stop timer</button>
          </div>
        </div>
      </div>

      <button class="theme-settings-button" aria-label="Theme settings" data-action="theme#open">
        <svg class="theme-settings-icon" viewBox="0 0 30 30" aria-hidden="true" style="fill: currentColor; stroke: none;">
          <g transform="translate(-101.000000, -360.000000)">
            <path d="M128.52,381.134 L127.528,382.866 C127.254,383.345 126.648,383.508 126.173,383.232 L123.418,381.628 C122.02,383.219 120.129,384.359 117.983,384.799 L117.983,387 C117.983,387.553 117.54,388 116.992,388 L115.008,388 C114.46,388 114.017,387.553 114.017,387 L114.017,384.799 C111.871,384.359 109.98,383.219 108.582,381.628 L105.827,383.232 C105.352,383.508 104.746,383.345 104.472,382.866 L103.48,381.134 C103.206,380.656 103.369,380.044 103.843,379.769 L106.609,378.157 C106.28,377.163 106.083,376.106 106.083,375 C106.083,373.894 106.28,372.838 106.609,371.843 L103.843,370.232 C103.369,369.956 103.206,369.345 103.48,368.866 L104.472,367.134 C104.746,366.656 105.352,366.492 105.827,366.768 L108.582,368.372 C109.98,366.781 111.871,365.641 114.017,365.201 L114.017,363 C114.017,362.447 114.46,362 115.008,362 L116.992,362 C117.54,362 117.983,362.447 117.983,363 L117.983,365.201 C120.129,365.641 122.02,366.781 123.418,368.372 L126.173,366.768 C126.648,366.492 127.254,366.656 127.528,367.134 L128.52,368.866 C128.794,369.345 128.631,369.956 128.157,370.232 L125.391,371.843 C125.72,372.838 125.917,373.894 125.917,375 C125.917,376.106 125.72,377.163 125.391,378.157 L128.157,379.769 C128.631,380.044 128.794,380.656 128.52,381.134 L128.52,381.134 Z M130.008,378.536 L127.685,377.184 C127.815,376.474 127.901,375.749 127.901,375 C127.901,374.252 127.815,373.526 127.685,372.816 L130.008,371.464 C130.957,370.912 131.281,369.688 130.733,368.732 L128.75,365.268 C128.203,364.312 126.989,363.983 126.041,364.536 L123.694,365.901 C122.598,364.961 121.352,364.192 119.967,363.697 L119.967,362 C119.967,360.896 119.079,360 117.983,360 L114.017,360 C112.921,360 112.033,360.896 112.033,362 L112.033,363.697 C110.648,364.192 109.402,364.961 108.306,365.901 L105.959,364.536 C105.011,363.983 103.797,364.312 103.25,365.268 L101.267,368.732 C100.719,369.688 101.044,370.912 101.992,371.464 L104.315,372.816 C104.185,373.526 104.099,374.252 104.099,375 C104.099,375.749 104.185,376.474 104.31