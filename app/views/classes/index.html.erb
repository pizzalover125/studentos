<div data-controller="classes">
  <div data-classes-target="storageWarning" class="storage-warning" hidden>
    Storage unavailable — your data won't be saved.
  </div>

  <div class="section-header">
    <h1 class="section-title">Classes</h1>
    <button class="btn btn--primary" data-action="classes#add">Add</button>
  </div>
  <div data-classes-target="form" hidden>
    <div class="inline-form">
      <div class="form-row">
        <div class="form-field">
          <label for="classes_name">Name</label>
          <input type="text" id="classes_name" data-classes-target="name" placeholder="e.g. AP Biology">
        </div>
        <div class="form-field">
          <label for="classes_description">Description</label>
          <input type="text" id="classes_description" data-classes-target="description" placeholder="Optional (e.g. Mr. Smith, Period 3)">
        </div>
      </div>
      <p class="error-msg" data-classes-target="error"></p>
      <div class="form-actions">
        <button class="btn btn--primary" data-action="classes#save">Save</button>
        <button class="btn btn--ghost" data-action="classes#cancel">Cancel</button>
      </div>
    </div>
  </div>

  <div data-classes-target="list"></div>
  <p class="edit-hint">click to edit</p>

  <div class="modal-backdrop" data-classes-target="modal" data-action="click->classes#closeEditorOnBackdrop" hidden>
    <div class="modal-card modal-card--with-close" role="dialog" aria-modal="true" aria-labelledby="classes_edit_heading">
      <button class="modal-close" aria-label="Close class editor" data-action="classes#closeEditor">&times;</button>
      <h2 id="classes_edit_heading" class="modal-title">Edit class</h2>
      <div class="form-row">
        <div class="form-field">
          <label for="classes_edit_name">Edit name</label>
          <input type="text" id="classes_edit_name" data-classes-target="modalName" placeholder="e.g. AP Biology">
        </div>
        <div class="form-field">
          <label for="classes_edit_description">Edit description</label>
          <input type="text" id="classes_edit_description" data-classes-target="modalDescription" placeholder="Optional (e.g. Mr. Smith, Period 3)">
        </div>
      </div>
      <p class="error-msg" data-classes-target="modalError"></p>
      <div class="form-actions">
        <button class="btn btn--primary" data-action="classes#saveEdit">Save changes</button>
        <button class="btn btn--danger" data-action="classes#requestDeleteConfirmation">Delete</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop modal-backdrop--confirm" data-classes-target="confirmModal" data-action="click->classes#closeDeleteConfirmOnBackdrop" hidden>
    <div class="modal-card modal-card--confirm" role="dialog" aria-modal="true" aria-labelledby="classes_delete_heading">
      <h2 id="classes_delete_heading" class="modal-title">Delete class?</h2>
      <p class="modal-copy">This action can’t be undone.</p>
      <div class="form-actions">
        <button class="btn btn--danger" data-action="classes#deleteFromModal">Delete item</button>
        <button class="btn btn--ghost" data-action="classes#closeDeleteConfirm">Cancel</button>
      </div>
    </div>
  </div>
</div>
